          "label": "CONTINUE",
          "complete_hint": "Complete the content above before moving on."
        },
        {
          "id": 5,
          "type": "image",
          "variant": "text_aside",
          "style": {
            "image_position": "right",
            "image_size": "small",
            "image_opacity": 0.5,
