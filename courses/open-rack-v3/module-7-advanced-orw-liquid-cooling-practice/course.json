    {
      "id": 3,
      "slug": "orw-liquid-cooling-mechanics",
      "title": "ORW Liquid Cooling Mechanics",
      "description_html": "",
      "blocks": [
        {
          "id": 1,
          "type": "image",
          "variant": "full",
          "style": {
            "background_type": "LIGHT",
            "card_mode": "WHITE",
