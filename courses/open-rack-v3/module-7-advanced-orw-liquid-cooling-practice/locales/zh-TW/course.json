            "padding_top": 3,
            "padding_bottom": 3
          },
          "body_html": "<p>在本模塊結束時，您將能夠：</p>"
        },
        {
          "id": 3,
          "type": "list",
          "variant": "bulleted",
          "style": {
            "attached_to_next": false,
