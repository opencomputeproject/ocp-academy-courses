    {
      "id": 3,
      "slug": "orw-liquid-cooling-mechanics",
      "title": "ORW 液體冷卻機制",
      "description_html": "",
      "blocks": [
        {
          "id": 1,
          "type": "image",
          "variant": "full",
          "style": {
            "background_type": "LIGHT",
