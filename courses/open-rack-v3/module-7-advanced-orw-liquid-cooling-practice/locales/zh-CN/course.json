          "id": 5,
          "type": "image",
          "variant": "text_aside",
          "style": {
            "image_position": "right",
            "image_size": "small",
            "image_opacity": 0.5,
            "image_opacity_color": "#000000",
            "zoom_on_click": true,
            "attached_to_next": false,
            "padding_top": 3,
