      "slug": "orw-power-shelves-busbar",
      "title": "Estantes eléctricos y barra colectora ORW",
      "description_html": "",
      "blocks": [
        {
          "id": 1,
          "type": "image",
          "variant": "full",
          "style": {
            "background_type": "LIGHT",
            "card_mode": "WHITE",
            "image_opacity": 0.5,
