    {
      "id": 1,
      "slug": "welcome-intro-learning-objectives",
      "title": "Bienvenidos, Introducción y Objetivos de Aprendizaje",
      "description_html": "",
      "blocks": [
        {
          "id": 1,
          "type": "image",
          "variant": "full",
          "style": {
            "background_type": "LIGHT",
            "card_mode": "WHITE",
