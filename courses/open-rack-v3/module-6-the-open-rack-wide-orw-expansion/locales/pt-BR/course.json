    {
      "id": 1,
      "slug": "welcome-intro-learning-objectives",
      "title": "Bem-vindo, introdução e objetivos de aprendizagem",
      "description_html": "",
      "blocks": [
        {
          "id": 1,
          "type": "image",
          "variant": "full",
          "style": {
            "background_type": "LIGHT",
