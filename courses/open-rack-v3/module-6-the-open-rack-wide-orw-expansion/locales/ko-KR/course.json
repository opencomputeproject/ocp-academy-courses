    {
      "id": 1,
      "slug": "welcome-intro-learning-objectives",
      "title": "환영, 소개 및 학습 목표",
      "description_html": "",
      "blocks": [
        {
          "id": 1,
          "type": "image",
          "variant": "full",
          "style": {
            "background_type": "LIGHT",
            "card_mode": "WHITE",
