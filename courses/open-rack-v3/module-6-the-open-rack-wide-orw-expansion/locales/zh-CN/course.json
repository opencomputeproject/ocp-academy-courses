    {
      "id": 1,
      "slug": "welcome-intro-learning-objectives",
      "title": "欢迎、介绍和学习目标",
      "description_html": "",
      "blocks": [
        {
          "id": 1,
          "type": "image",
          "variant": "full",
          "style": {
            "background_type": "LIGHT",
            "card_mode": "WHITE",
            "image_opacity": 0.5,
            "image_opacity_color": "#000000",
            "zoom_on_click": false,
            "attached_to_next": false,
            "padding_top": 0,
