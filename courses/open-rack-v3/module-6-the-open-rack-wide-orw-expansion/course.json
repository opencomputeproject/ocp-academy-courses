    {
      "id": 3,
      "slug": "inside-the-orw-frame",
      "title": "Inside the ORW Frame",
      "description_html": "",
      "blocks": [
        {
          "id": 1,
          "type": "image",
          "variant": "full",
          "style": {
            "background_type": "LIGHT",
            "card_mode": "WHITE",
