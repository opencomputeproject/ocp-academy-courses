      "slug": "welcome-intro-learning-objectives",
      "title": "Welcome, Intro & Learning Objectives",
      "description_html": "",
      "blocks": [
        {
          "id": 1,
          "type": "image",
          "variant": "full",
          "style": {
            "background_type": "LIGHT",
            "card_mode": "WHITE",
