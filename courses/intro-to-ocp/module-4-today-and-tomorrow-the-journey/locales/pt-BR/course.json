            "custom_padding_top": 0,
            "custom_padding_bottom": 0,
            "entrance_animation": true
          },
          "media": {
            "path": "resources/images/black-banner-intro-1.png",
            "alt": "Faixa preta de introdução",
            "source_asset": "Black banner - intro-1.png",
            "dimensions": {
              "originalWidth": 1680,
              "originalHeight": 295
            }
          }
        },
        {
          "id": 2,
          "type": "text",
          "variant": "heading_paragraph",
          "style": {
            "background_type": "COLOR",
            "background_color": "#1c1c1c",
            "attached_to_next": false,
            "padding_top": 3,
            "padding_bottom": 3
          },
          "heading_html": "<p>Etapas para implantação</p>",
          "body_html": "<p>A adoção de infraestrutura aberta é um processo estratégico. <br><br>Siga estas etapas principais para garantir uma transição suave: </p>"
        },
        {
          "id": 3,
          "type": "process",
          "variant": "process",
          "style": {
            "background_type": "COLOR",
            "background_color": "#1c1c1c",
            "zoom_on_click": true,
            "attached_to_next": false,
            "padding_top": 3,
            "padding_bottom": 3,
            "media_width": "1"
          },
          "items": [
            {
              "type": "intro",
              "title": "Introdução",
              "hidden": false,
              "description_html": "<p>Descubra as etapas essenciais para adotar e implementar a estrutura de forma eficaz. Siga estas diretrizes para garantir uma transição suave e resultados ideais.</p>"
            },
            {
              "type": "step",
              "title": "Avaliar",
              "hidden": false,
              "description_html": "<p>Avalie suas <strong>cargas de trabalho atuais</strong>, limitações de energia e desafios térmicos para compreender o ponto de partida e identificar oportunidades de melhoria.</p>"
            },
            {
              "type": "step",
              "title": "Identificar",
              "hidden": false,
              "description_html": "<p>Use o OCP Marketplace para encontrar <strong>soluções de hardware</strong> compatíveis com seus requisitos específicos de densidade e operação.</p>"
            },
            {
              "type": "step",
              "title": "Formar parceria",
              "hidden": false,
              "description_html": "<p>Trabalhe com um <strong>OCP Solution Provider</strong> para desenvolver um <strong>plano de integração completo</strong>, adequado às suas necessidades.</p>"
            },
            {
              "type": "step",
              "title": "Implantar",
              "hidden": false,
              "description_html": "<p>Comece com uma <strong>implantação em pequena escala</strong>, como um único rack ou pod piloto, antes de avançar para uma <strong>implantação completa da instalação</strong>.</p>"
            },
            {
              "type": "summary",
              "title": "Conclusão",
              "hidden": false,
              "description_html": "<p>Seguindo estas etapas, você pode adotar a estrutura de forma eficaz e atingir seus objetivos com confiança e eficiência.</p>"
            }
          ]
        },
        {
