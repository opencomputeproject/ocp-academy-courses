    {
      "id": 5,
      "slug": "the-adoption-framework",
      "title": "A estrutura de adoção",
      "description_html": "",
      "blocks": [
        {
          "id": 1,
          "type": "image",
          "variant": "full",
          "style": {
            "background_type": "LIGHT",
            "card_mode": "WHITE",
            "image_opacity": 0.5,
            "image_opacity_color": "#000000",
            "zoom_on_click": true,
            "attached_to_next": false,
            "padding_top": 0,
