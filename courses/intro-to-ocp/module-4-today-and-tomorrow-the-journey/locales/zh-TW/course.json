            {
              "text_html": "<p>OCP Ready</p>",
              "correct": false
            },
            {
              "text_html": "<p>OCP Accepted</p>",
              "correct": true
            },
            {
              "text_html": "<p>OCP 認證</p>",
              "correct": false
            }
          ],
          "feedback_correct_html": "<p>回答正確！ OCP Accepted 硬體表示完全符合現有且已批准的 OCP 貢獻的產品</p>",
          "feedback_incorrect_html": "<p>不正確。 OCP Ready™ 指設施。 正確答案是OCP Accepted。</p>"
