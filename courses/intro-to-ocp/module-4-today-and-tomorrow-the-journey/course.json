            "padding_top": 3,
            "padding_bottom": 3,
            "entrance_animation": true
          },
          "question_type": "multiple_choice",
          "question_html": "<p>Which tier of OCP recognition signifies products that &nbsp;comply with an existing and approved OCP contribution?</p>",
          "choices": [
            {
              "text_html": "<p>Powered by OCP </p>",
              "correct": false
            },
            {
              "text_html": "<p>OCP Ready</p>",
              "correct": false
            },
            {
              "text_html": "<p>OCP Accepted</p>",
              "correct": true
            },
            {
              "text_html": "<p>OCP Certified</p>",
              "correct": false
            }
          ],
          "feedback_correct_html": "<p>Correct! OCP Accepted&nbsp;hardware signifies products that fully comply an existing and approved OCP contribution</p>",
          "feedback_incorrect_html": "<p>Incorrect. OCP Ready™ refers to facilities. The correct answer is OCP Accepted.</p>"
        },
