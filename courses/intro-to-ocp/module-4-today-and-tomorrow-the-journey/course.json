            "entrance_animation": true
          },
          "question_type": "multiple_choice",
          "question_html": "<p>True or False? To participate in the OCP Community, you must be an OCP member? </p>",
          "choices": [
            {
              "text_html": "<p>True</p>",
              "correct": false
            },
            {
              "text_html": "<p>False</p>",
              "correct": true
            }
          ],
          "feedback_correct_html": "<p>Correct! OCP adoption as well as participation in the Community Projects is free and open to anyone.</p>",
          "feedback_incorrect_html": "<p>Incorrect. OCP adoption as well as participation in the Community Projects is free and open to anyone.</p>"
        },
