            "padding_bottom": 3,
            "entrance_animation": true
          },
          "question_type": "multiple_choice",
          "question_html": "<p>True or False? You must rebuild your entire data center from scratch to adopt OCP hardware.</p>",
          "choices": [
            {
              "text_html": "<p>True</p>",
              "correct": false
            },
            {
              "text_html": "<p>False</p>",
              "correct": true
            }
          ],
          "feedback_correct_html": "<p>Correct! You do not need to rebuild your data center from scratch. The journey to open infrastructure can start with just a single rack or pilot pod.</p>",
          "feedback_incorrect_html": "<p>Incorrect. Transitioning to open hardware does not require an immediate, massive overhaul. You can start small, even with a single rack, and scale up from there.</p>"
        },
        {
          "id": 6,
          "type": "knowledge_check",
          "variant": "multiple_choice",
