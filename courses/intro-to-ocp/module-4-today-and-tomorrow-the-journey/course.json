            "entrance_animation": true
          },
          "body_html": "<p>Test your knowledge from this module. Select the best answer for each question, then submit.</p>"
        },
        {
          "id": 3,
          "type": "knowledge_check",
          "variant": "multiple_choice",
          "style": {
